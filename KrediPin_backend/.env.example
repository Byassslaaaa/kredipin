# Contoh konfigurasi KrediPin Backend.
# Salin menjadi .env lalu sesuaikan bila perlu. Semua punya default di config.py.

# Ambang keputusan (0..1). probabilitas_layak >= THRESHOLD -> "Layak".
THRESHOLD=0.5

# Origin frontend yang diizinkan. Boleh dipisah koma ATAU JSON list.
# Untuk produksi, isi dengan domain frontend Anda.
# CORS_ORIGINS=https://app.contoh.com,https://www.contoh.com
# CORS_ORIGINS=["http://localhost:5173","http://127.0.0.1:5173"]

# Nama file database SQLite (disimpan di folder database/).
# DATABASE_FILE=krediPin_history.db
